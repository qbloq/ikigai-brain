# Connection to the org's Postgres. Both are REQUIRED — the genome presupposes
# no database and no schema: each brain declares its own ("el cerebro nace
# conectado, no poblado").
#
# DATABASE_URL: the standard libpq connection string for this org.
# DB_SCHEMA:    the Postgres schema that holds the org's operational tables.
DATABASE_URL=
DB_SCHEMA=

# Optional — timezone used to evaluate dates (default: America/Bogota).
#BRAIN_TZ=America/Bogota

# Copilots only — the brain's API (third-party tokens live server-side;
# this pair replaces NOTION= and friends on employee machines).
#CEREBRO_API=https://<host>/cerebro
#CEREBRO_TOKEN=<hex del alta>

# Optional — the org's own name as it appears in its data (teams/persons).
# Drives "the org vs project owner" resolution (revenue shares, team lookups).
# Empty = those resolutions degrade gracefully (todo al owner / por id).
ORG_NAME=
