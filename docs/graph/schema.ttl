@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ent:  <https://ikigai.parallelo.ai/ontology/entity#> .
@prefix rel:  <https://ikigai.parallelo.ai/ontology/relation#> .
@prefix dom:  <https://ikigai.parallelo.ai/ontology/domain#> .
@prefix rule: <https://ikigai.parallelo.ai/ontology/rule#> .

### Domains (grouping concepts)
dom:tasks a owl:Class ; rdfs:label "Tareas"@es .
dom:meetings a owl:Class ; rdfs:label "Reuniones"@es .
dom:crm a owl:Class ; rdfs:label "CRM / Ventas"@es .
dom:ads a owl:Class ; rdfs:label "Pauta (Meta)"@es .
dom:finance a owl:Class ; rdfs:label "Finanzas"@es .
dom:catalog a owl:Class ; rdfs:label "Ontología de procesos"@es .
dom:people a owl:Class ; rdfs:label "Personas / Equipo"@es .
dom:projects a owl:Class ; rdfs:label "Proyectos / Config"@es .
dom:okr a owl:Class ; rdfs:label "OKR / KPI"@es .
dom:runtime a owl:Class ; rdfs:label "Runtime agéntico / LLM"@es .
dom:content a owl:Class ; rdfs:label "Contenido (Notion/Drive)"@es .
dom:whatsapp a owl:Class ; rdfs:label "WhatsApp"@es .
dom:misc a owl:Class ; rdfs:label "Otros"@es .

### Entities (tables/views as classes)
ent:activity_archetypes a owl:Class ;
    rdfs:label "activity_archetypes" ;
    rdfs:subClassOf dom:catalog ;
    rule:primaryKey "id" ;
    rule:unique "slug" ;
