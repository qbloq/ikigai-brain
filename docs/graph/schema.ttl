### Rules: enumerated value sets (enum types and CHECK-as-enum)
ent:artifact_types rule:enumerated [ rule:column "resolver_type" ; rule:datatype "check" ; rule:oneOf "table|storage|api|computed|inline|gdrive|sql|notion" ] .
ent:artifact_types rule:enumerated [ rule:column "category" ; rule:datatype "check" ; rule:oneOf "document|approval|data|resource|decision" ] .
ent:commission_payouts rule:enumerated [ rule:column "commission_type" ; rule:datatype "commission_type" ; rule:oneOf "sale|lead|service" ] .
ent:commission_payouts rule:enumerated [ rule:column "rule_value_type" ; rule:datatype "commission_value_type" ; rule:oneOf "fixed|pct_installment|pct_plan_total" ] .
ent:commission_payouts rule:enumerated [ rule:column "status" ; rule:datatype "payout_status" ; rule:oneOf "pending|approved|paid|rejected|cancelled" ] .
ent:commission_rules rule:enumerated [ rule:column "commission_type" ; rule:datatype "commission_type" ; rule:oneOf "sale|lead|service" ] .
ent:commission_rules rule:enumerated [ rule:column "value_type" ; rule:datatype "commission_value_type" ; rule:oneOf "fixed|pct_installment|pct_plan_total" ] .
ent:economics_ledger rule:enumerated [ rule:column "entry_type" ; rule:datatype "check" ; rule:oneOf "revenue|expense_opex|expense_payroll|expense_commission|distribution" ] .
ent:expense_templates rule:enumerated [ rule:column "recurrence" ; rule:datatype "cost_recurrence" ; rule:oneOf "one_time|weekly|biweekly|monthly|quarterly|annual" ] .
ent:expenses rule:enumerated [ rule:column "recurrence" ; rule:datatype "cost_recurrence" ; rule:oneOf "one_time|weekly|biweekly|monthly|quarterly|annual" ] .
ent:graph_messages rule:enumerated [ rule:column "role" ; rule:datatype "check" ; rule:oneOf "user|assistant" ] .
ent:installments rule:enumerated [ rule:column "status" ; rule:datatype "installment_status" ; rule:oneOf "Scheduled|Paid|Overdue|Cancelled|Partial" ] .
ent:io_types rule:enumerated [ rule:column "category" ; rule:datatype "check" ; rule:oneOf "document|approval|data|resource|decision" ] .
ent:key_results rule:enumerated [ rule:column "scoring" ; rule:datatype "kr_scoring" ; rule:oneOf "binary|percentage|threshold" ] .
ent:objectives rule:enumerated [ rule:column "cadence" ; rule:datatype "okr_cadence" ; rule:oneOf "weekly|monthly|quarterly|annual" ] .
ent:objectives rule:enumerated [ rule:column "status" ; rule:datatype "okr_status" ; rule:oneOf "draft|active|completed|cancelled" ] .
ent:output_channels rule:enumerated [ rule:column "channel_type" ; rule:datatype "check" ; rule:oneOf "sql_table|html_report|csv_file|http_webhook|email|whatsapp|slack" ] .
ent:payment_plans rule:enumerated [ rule:column "installment_frequency" ; rule:datatype "installment_frequency" ; rule:oneOf "Monthly|Bi-weekly|Weekly|Quarterly|Semi-annual|Annual" ] .
ent:payment_plans rule:enumerated [ rule:column "plan_status" ; rule:datatype "payment_plan_status" ; rule:oneOf "Active|Completed|Cancelled|Defaulted" ] .
ent:payroll_actuals rule:enumerated [ rule:column "status" ; rule:datatype "payout_status" ; rule:oneOf "pending|approved|paid|rejected|cancelled" ] .
ent:payroll_rules rule:enumerated [ rule:column "employment_type" ; rule:datatype "employment_type" ; rule:oneOf "contracted|commissioned" ] .
ent:payroll_rules rule:enumerated [ rule:column "frequency" ; rule:datatype "payroll_frequency" ; rule:oneOf "weekly|biweekly|monthly" ] .
ent:payroll_rules rule:enumerated [ rule:column "rate_unit" ; rule:datatype "payroll_rate_unit" ; rule:oneOf "h|d|w|m" ] .
ent:projects rule:enumerated [ rule:column "video_provider_key" ; rule:datatype "check" ; rule:oneOf "panda|vturb" ] .
ent:prompt_sections rule:constraint "quality_rating >= 1) AND (quality_rating <= 5" .
ent:revenue_share_payouts rule:enumerated [ rule:column "status" ; rule:datatype "payout_status" ; rule:oneOf "pending|approved|paid|rejected|cancelled" ] .
ent:revenue_share_rules rule:constraint "share_pct > (0)::numeric) AND (share_pct <= (1)::numeric" .
ent:runner_runs rule:enumerated [ rule:column "status" ; rule:datatype "check" ; rule:oneOf "pending|running|success|partial|error" ] .
ent:runners rule:enumerated [ rule:column "trigger_type" ; rule:datatype "check" ; rule:oneOf "cron|event|manual" ] .
ent:runners rule:enumerated [ rule:column "status" ; rule:datatype "check" ; rule:oneOf "active|paused|error" ] .
ent:sql_messages rule:enumerated [ rule:column "role" ; rule:datatype "check" ; rule:oneOf "user|assistant" ] .
ent:task_acceptance_criteria rule:enumerated [ rule:column "pass_threshold" ; rule:datatype "check" ; rule:oneOf "high|medium|low" ] .
ent:task_acceptance_criteria rule:enumerated [ rule:column "verification_method" ; rule:datatype "check" ; rule:oneOf "llm|manual|automated|test|attested" ] .
ent:task_acceptance_criteria rule:enumerated [ rule:column "confidence" ; rule:datatype "check" ; rule:oneOf "high|medium|low" ] .
ent:task_attestations rule:enumerated [ rule:column "channel" ; rule:datatype "check" ; rule:oneOf "whatsapp|app|email" ] .
ent:task_attestations rule:enumerated [ rule:column "status" ; rule:datatype "check" ; rule:oneOf "pending|sent|answered|expired|escalated" ] .
ent:tasks rule:enumerated [ rule:column "priority" ; rule:datatype "task_priority" ; rule:oneOf "Low|Medium|High" ] .
ent:tasks rule:enumerated [ rule:column "status" ; rule:datatype "task_status" ; rule:oneOf "pending|in_progress|completed|blocked|cancelled" ] .
ent:teams rule:enumerated [ rule:column "team_type" ; rule:datatype "check" ; rule:oneOf "operations|sales|partners|services" ] .
ent:worker_runs rule:enumerated [ rule:column "status" ; rule:datatype "check" ; rule:oneOf "pending|running|success|error" ] .
ent:workers rule:enumerated [ rule:column "status" ; rule:datatype "check" ; rule:oneOf "active|paused|error" ] .
ent:workers rule:enumerated [ rule:column "worker_type" ; rule:datatype "check" ; rule:oneOf "gemini_structured|ax_llm|graph" ] .

