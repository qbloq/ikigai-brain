### Relations (FK = object properties; implicit flagged)
rel:activity_archetypes__sop_code__sops a owl:ObjectProperty ;
    rdfs:domain ent:activity_archetypes ;
    rdfs:range  ent:sops ;
    rdfs:label "sop_code→code" ;
    rdfs:comment "foreign key"@es .
