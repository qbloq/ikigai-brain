@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix biz:  <https://ikigai.parallelo.ai/ontology/business#> .
@prefix ent:  <https://ikigai.parallelo.ai/ontology/entity#> .
@prefix mp:   <https://ikigai.parallelo.ai/business/macro#> .
@prefix sop:  <https://ikigai.parallelo.ai/business/sop#> .
@prefix arq:  <https://ikigai.parallelo.ai/business/arquetipo#> .
@prefix rol:  <https://ikigai.parallelo.ai/business/rol#> .
@prefix proj: <https://ikigai.parallelo.ai/business/cliente#> .
@prefix io:   <https://ikigai.parallelo.ai/business/entregable#> .

### Concept classes, each bridged to the tables that realize it
biz:MacroProceso a owl:Class ; rdfs:label "Macro-proceso"@es ;
    biz:realizadoPor ent:macro_processes .
biz:SOP a owl:Class ; rdfs:label "SOP"@es ;
    biz:realizadoPor ent:sops .
biz:ArquetipoDeActividad a owl:Class ; rdfs:label "Arquetipo de actividad"@es ;
    biz:realizadoPor ent:activity_archetypes ; biz:realizadoPor ent:archetype_inputs ; biz:realizadoPor ent:archetype_outputs ; biz:realizadoPor ent:archetype_acceptance_criteria ; biz:realizadoPor ent:tasks .
biz:Rol a owl:Class ; rdfs:label "Rol"@es ;
    biz:realizadoPor ent:team_roles ; biz:realizadoPor ent:team_members ; biz:realizadoPor ent:users ; biz:realizadoPor ent:persons .
biz:Cliente a owl:Class ; rdfs:label "Cliente / Proyecto"@es ;
    biz:realizadoPor ent:projects .
biz:TipoDeEntregable a owl:Class ; rdfs:label "Tipo de entregable"@es ;
    biz:realizadoPor ent:io_types ; biz:realizadoPor ent:artifact_types ; biz:realizadoPor ent:task_inputs ; biz:realizadoPor ent:task_outputs .

### Relations
biz:precedeA a owl:ObjectProperty ; rdfs:label "precede"@es ; biz:evidencia "declarada" .
biz:seDescomponeEn a owl:ObjectProperty ; rdfs:label "descompone"@es ; biz:evidencia "declarada" .
biz:agrupa a owl:ObjectProperty ; rdfs:label "agrupa"@es ; biz:evidencia "declarada" .
biz:tieneDueño a owl:ObjectProperty ; rdfs:label "dueño"@es ; biz:evidencia "declarada" .
biz:ejecuta a owl:ObjectProperty ; rdfs:label "ejecuta"@es ; biz:evidencia "observada" .
biz:consume a owl:ObjectProperty ; rdfs:label "consume"@es ; biz:evidencia "observada" .
biz:requiere a owl:ObjectProperty ; rdfs:label "requiere"@es ; biz:evidencia "declarada" .
biz:produce a owl:ObjectProperty ; rdfs:label "produce"@es ; biz:evidencia "declarada" .

